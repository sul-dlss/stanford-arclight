<div class="al-grouped-card">
  <div class='al-grouped-title-bar'>
    <div class='row'>
      <div class='col-md-12'>
        <% if document.repository_config.present? %>
          <div class='al-grouped-repository breadcrumb-links'>
            <%= link_to(document.repository_config.name, helpers.search_action_url(f: { repository: [document.repository_config.name], level: ['Collection'] })) %>
          </div>
        <% end %>
        <h3>
          <span class="al-grouped-collection-tag">Collection</span>
          <span class="d-inline-block mb-2 me-2 lh-base">
            <span class="me-2">
              <%= helpers.link_to_document document %>
            </span>
            <span class="d-inline-block">
              <%= render CollectionUnitidPillComponent.new(document: document) %>
              <%= render Arclight::OnlineStatusIndicatorComponent.new(document: document) %>
            </span>
          </span>
        </h3>
        <div class="d-flex flex-wrap align-items-center gap-2">
          <%= render ExtentPillComponent.new(document: document, compact: compact?) %>
          <% if collection_doc_in_results %>
            <span class="collection-description-matched-pill">
              <span class="collection-description-matched-indicator" aria-hidden="true"></span>
              <% if component_docs.any? %>
                <%= t('arclight.views.index.collection_description_matched') %>
              <% else %>
                <%= t('arclight.views.index.collection_description_only_matched') %>
              <% end %>
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="grouped-documents">
    <% if component_docs.any? %>
      <div class="al-grouped-components">
        <% component_docs.each do |doc| %>
          <%= render GroupedSearchResultComponent.new(document: doc) %>
        <% end %>
      </div>
    <% end %>
    <div class="al-grouped-footer d-flex justify-content-between align-items-center">
      <% unless collection_doc_in_results && component_docs.empty? %>
        <span class="al-grouped-footer-count">
          <% if collection_doc_in_results %>
            <%= t('arclight.views.index.group_component_results_count', count: component_count) %>
          <% elsif @group.total > 3 %>
            <%= t('arclight.views.index.group_results_count_more') %>
          <% else %>
            <%= t('arclight.views.index.group_results_count', count: @group.total) %>
          <% end %>
        </span>
      <% end %>
      <% if collection_doc_in_results && component_docs.empty? %>
        <%= link_to(t('arclight.views.index.explore_collection') + " \u2192", collection_show_url,
                    class: 'al-grouped-footer-link') %>
      <% elsif more_component_results? %>
        <%= link_to(t('arclight.views.index.all_group_results', count: helpers.number_with_delimiter(component_count)) + " \u2192",
                    search_within_collection_url, class: 'al-grouped-footer-link') %>
      <% end %>
    </div>
  </div>
</div>
